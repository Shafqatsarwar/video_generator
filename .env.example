# Google Gemini API Key for AI script generation
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API Key for high-fidelity TTS (Optional)
# If provided, the engine will use OpenAI instead of local Windows voice.
OPENAI_API_KEY=your_openai_api_key_here

# ElevenLabs API Key for premium voices (Optional)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Branding Configuration (Overrides defaults)
BRAND_NAME=MyBrand
BRAND_WEBSITE=example.com
BRAND_COLOR=#2563eb

# Rendering Settings
RENDER_TIMEOUT=300000
MAX_CONCURRENCY=4
DEFAULT_RESOLUTION=1080p
DEFAULT_FPS=30
