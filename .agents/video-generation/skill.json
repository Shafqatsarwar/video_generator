{
  "name": "video-generation",
  "version": "2.0.0",
  "description": "Enhanced skill for generating demo videos for AgentFactory platform with evaluation metrics",
  "author": "Panaverse",
  "license": "MIT",
  "entrypoint": "./video-generation-improved.skill",
  "dependencies": [
    "remotion",
    "ffmpeg"
  ],
  "evaluationCriteria": {
    "accuracy": {
      "description": "How well the generated video matches the specification",
      "benchmark": 0.90
    },
    "performance": {
      "description": "Execution time relative to video duration",
      "benchmark": 30000
    },
    "reliability": {
      "description": "Success rate of video generation",
      "benchmark": 0.95
    },
    "usability": {
      "description": "Ease of use and parameter validation",
      "benchmark": 0.80
    }
  },
  "parameters": {
    "title": {
      "type": "string",
      "description": "Title of the video",
      "required": true,
      "minLength": 3,
      "maxLength": 200
    },
    "description": {
      "type": "string",
      "description": "Brief description of the video content",
      "required": false
    },
    "videoType": {
      "type": "string",
      "description": "Type of video to generate",
      "required": false,
      "default": "default",
      "enum": [
        "tutorial",
        "feature-walkthrough",
        "product-overview",
        "case-study",
        "default"
      ]
    },
    "keyPoints": {
      "type": "array",
      "description": "Key points to cover in the video",
      "required": false,
      "items": {
        "type": "string"
      },
      "maxItems": 20
    },
    "duration": {
      "type": "number",
      "description": "Desired duration in seconds",
      "required": false,
      "default": 60,
      "minimum": 10,
      "maximum": 600
    },
    "targetAudience": {
      "type": "string",
      "description": "Target audience for the video",
      "required": false,
      "default": "Developers"
    },
    "assets": {
      "type": "array",
      "description": "Required assets for the video",
      "required": false,
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "image",
              "video",
              "audio",
              "font"
            ]
          },
          "path": {
            "type": "string"
          },
          "placement": {
            "type": "string",
            "enum": [
              "top-left",
              "top-right",
              "center",
              "bottom"
            ]
          }
        },
        "required": [
          "type",
          "path"
        ]
      }
    },
    "quality": {
      "type": "string",
      "description": "Output quality setting",
      "required": false,
      "default": "high",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "resolution": {
      "type": "string",
      "description": "Output resolution",
      "required": false,
      "default": "1080p",
      "enum": [
        "720p",
        "1080p",
        "4k"
      ]
    },
    "outputFormat": {
      "type": "string",
      "description": "Output video format",
      "required": false,
      "default": "mp4",
      "enum": [
        "mp4",
        "webm"
      ]
    },
    "story": {
      "type": "object",
      "description": "V2.0 Story structure for the video",
      "required": false,
      "properties": {
        "hook": {
          "type": "string",
          "description": "Engaging opening hook"
        },
        "problem": {
          "type": "string",
          "description": "Problem or pain point"
        },
        "demo": {
          "type": "string",
          "description": "Brief demo description"
        },
        "benefit": {
          "type": "string",
          "description": "Key value proposition"
        },
        "cta": {
          "type": "string",
          "description": "Call to action"
        }
      }
    },
    "timeout": {
      "type": "number",
      "description": "Render timeout in milliseconds",
      "required": false,
      "default": 300000
    },
    "maxConcurrentJobs": {
      "type": "number",
      "description": "Maximum concurrent render jobs",
      "required": false,
      "default": 1
    }
  },
  "examples": [
    {
      "title": "Basic Tutorial",
      "parameters": {
        "title": "Getting Started",
        "description": "Learn the basics",
        "videoType": "tutorial",
        "keyPoints": [
          "Setup",
          "Configuration",
          "Testing"
        ],
        "duration": 60
      }
    },
    {
      "title": "Product Overview",
      "parameters": {
        "title": "AgentFactory Overview",
        "description": "Platform capabilities",
        "videoType": "product-overview",
        "keyPoints": [
          "Features",
          "Benefits",
          "Getting Started"
        ],
        "duration": 90,
        "quality": "high",
        "resolution": "1080p"
      }
    }
  ]
}