#!/usr/bin/env node

// Video Generation Skill for AgentFactory
// This skill generates demo videos based on provided specifications

const { VideoGeneratorAgent } = require('../../video-generator');

/**
 * Execute the video generation skill
 * @param {Object} parameters - Skill parameters
 * @returns {Promise<Object>} - Execution result
 */
async function executeSkill(parameters) {
  console.log('Executing video generation skill...');
  console.log('');

  // Validate required parameters
  const validation = validateParameters(parameters);
  if (!validation.valid) {
    return {
      success: false,
      error: validation.errors.join(', '),
      message: 'Invalid parameters provided'
    };
  }

  // Initialize agent with configuration
  const agent = new VideoGeneratorAgent({
    renderTimeout: parameters.timeout || 300000,
    maxConcurrentJobs: parameters.maxConcurrentJobs || 1,
    outputFormat: parameters.outputFormat || 'mp4',
    quality: parameters.quality || 'high',
    resolution: parameters.resolution || '1080p',
    fps: parameters.fps || 30
  });

  try {
    // Prepare video specification
    const specification = {
      title: parameters.title,
      description: parameters.description || 'Demo video',
      videoType: parameters.videoType || 'default',
      keyPoints: parameters.keyPoints || [],
      duration: parameters.duration || 60,
      targetAudience: parameters.targetAudience || 'Developers',
      assets: parameters.assets || []
    };

    console.log('Video Specification:');
    console.log(`  Title: ${specification.title}`);
    console.log(`  Type: ${specification.videoType}`);
    console.log(`  Duration: ${specification.duration}s`);
    console.log(`  Key Points: ${specification.keyPoints.length}`);
    console.log('');

    // Generate the video
    const videoPath = await agent.generateDemoVideo(specification);

    console.log('');
    console.log('Video generation completed successfully');

    // Return result in the expected format
    return {
      success: true,
      outputPath: videoPath,
      message: `Video generated successfully at ${videoPath}`,
      metadata: {
        title: specification.title,
        duration: specification.duration,
        videoType: specification.videoType
      }
    };
  } catch (error) {
    console.error('Video generation failed:', error.message);

    return {
      success: false,
      error: error.message,
      message: 'Video generation failed',
      stack: error.stack
    };
  }
}

/**
 * Validate input parameters
 * @param {Object} params - Parameters to validate
 * @returns {Object} - Validation result
 */
function validateParameters(params) {
  const errors = [];

  if (!params || typeof params !== 'object') {
    return {
      valid: false,
      errors: ['Parameters must be an object']
    };
  }

  // Title is required
  if (!params.title || typeof params.title !== 'string') {
    errors.push('Title is required and must be a string');
  } else if (params.title.length < 3) {
    errors.push('Title must be at least 3 characters');
  } else if (params.title.length > 200) {
    errors.push('Title must not exceed 200 characters');
  }

  // Duration validation
  if (params.duration !== undefined) {
    if (typeof params.duration !== 'number') {
      errors.push('Duration must be a number');
    } else if (params.duration < 10) {
      errors.push('Duration must be at least 10 seconds');
    } else if (params.duration > 600) {
      errors.push('Duration must not exceed 600 seconds (10 minutes)');
    }
  }

  // Key points validation
  if (params.keyPoints !== undefined) {
    if (!Array.isArray(params.keyPoints)) {
      errors.push('KeyPoints must be an array');
    } else if (params.keyPoints.length === 0) {
      console.warn('Warning: No key points provided. Video will have minimal content.');
    } else if (params.keyPoints.length > 20) {
      errors.push('KeyPoints must not exceed 20 items');
    }
  }

  // Video type validation
  const validTypes = ['tutorial', 'feature-walkthrough', 'product-overview', 'case-study', 'default'];
  if (params.videoType !== undefined && !validTypes.includes(params.videoType)) {
    errors.push(`VideoType must be one of: ${validTypes.join(', ')}`);
  }

  // Quality validation
  const validQualities = ['high', 'medium', 'low'];
  if (params.quality !== undefined && !validQualities.includes(params.quality)) {
    errors.push(`Quality must be one of: ${validQualities.join(', ')}`);
  }

  // Resolution validation
  const validResolutions = ['720p', '1080p', '4k'];
  if (params.resolution !== undefined && !validResolutions.includes(params.resolution)) {
    errors.push(`Resolution must be one of: ${validResolutions.join(', ')}`);
  }

  return {
    valid: errors.length === 0,
    errors
  };
}

/**
 * Get skill information
 * @returns {Object} - Skill metadata
 */
function getSkillInfo() {
  return {
    name: 'video-generation',
    version: '1.0.0',
    description: 'Skill for generating demo videos for AgentFactory',
    parameters: {
      title: { type: 'string', required: true, description: 'Title of the video' },
      description: { type: 'string', required: false, description: 'Brief description of the video content' },
      videoType: { 
        type: 'string', 
        required: false, 
        description: 'Type of video',
        options: ['tutorial', 'feature-walkthrough', 'product-overview', 'case-study', 'default']
      },
      keyPoints: { type: 'array', required: false, description: 'Key points to cover in the video' },
      duration: { type: 'number', required: false, default: 60, description: 'Desired duration in seconds (10-600)' },
      targetAudience: { type: 'string', required: false, default: 'Developers', description: 'Target audience for the video' },
      assets: { type: 'array', required: false, description: 'Required assets for the video' },
      quality: { type: 'string', required: false, default: 'high', options: ['high', 'medium', 'low'] },
      resolution: { type: 'string', required: false, default: '1080p', options: ['720p', '1080p', '4k'] },
      outputFormat: { type: 'string', required: false, default: 'mp4', options: ['mp4', 'webm'] },
      timeout: { type: 'number', required: false, default: 300000, description: 'Render timeout in milliseconds' }
    }
  };
}

// Handle command line execution
if (require.main === module) {
  const args = process.argv.slice(2);

  if (args.length === 0) {
    console.log('Video Generation Skill');
    console.log('');
    console.log('Usage: video-generation.skill <parameters-as-json>');
    console.log('');
    console.log('Example:');
    console.log('  video-generation.skill \'{"title":"My Demo","description":"A demonstration","keyPoints":["Point 1","Point 2"],"duration":60}\'');
    console.log('');
    console.log('Options:');
    console.log('  --info    Show skill information');
    console.log('  --help    Show this help message');
    console.log('');
    process.exit(0);
  }

  // Handle special flags
  if (args[0] === '--info') {
    console.log(JSON.stringify(getSkillInfo(), null, 2));
    process.exit(0);
  }

  if (args[0] === '--help') {
    console.log('Usage: video-generation.skill <parameters-as-json>');
    console.log('');
    console.log('Provide parameters as a JSON string.');
    console.log('');
    process.exit(0);
  }

  // Parse and execute
  try {
    const parameters = JSON.parse(args[0]);
    
    executeSkill(parameters)
      .then(result => {
        console.log('');
        console.log(JSON.stringify(result, null, 2));
        process.exit(result.success ? 0 : 1);
      })
      .catch(error => {
        console.error('Skill execution error:', error.message);
        process.exit(1);
      });
  } catch (error) {
    console.error('Invalid JSON parameters:', error.message);
    console.log('');
    console.log('Usage: video-generation.skill <parameters-as-json>');
    console.log('');
    process.exit(1);
  }
}

module.exports = { executeSkill, validateParameters, getSkillInfo };
